generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id       Int      @id @default(autoincrement())
  roomCode String   @unique
  letter   String
  topic    String
  answers  Answer[]

  @@map("games")
}

model Answer {
  id       Int    @id @default(autoincrement())
  answer   String
  username String
  gameId   Int
  game     Game   @relation(fields: [gameId], references: [id]) 

  @@unique([gameId, answer])
  @@map("answer")
}