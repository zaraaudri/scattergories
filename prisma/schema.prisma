generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model answer {
  id       Int     @id
  gameId   Int?
  username String?
  answer   String?

  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model games {
  id       Int     @id
  roomCode String? @unique(map: "games_room_code_unique")
  letter   String?
  topic    String?

  @@ignore
}
